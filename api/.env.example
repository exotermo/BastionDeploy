# BastionDeploy API — configuration template
# Copie para .env e preencha os valores

PORT=8080
GIN_MODE=release

# Origens permitidas (CORS) — domínios do dashboard/proxy
ALLOWED_ORIGINS=http://localhost:5173

# Secret do webhook do GitHub (gerado por: exoctl gen-secret)
GITHUB_WEBHOOK_SECRET=

# Chave de API — protege todos os endpoints GET /api/v1/*
# Gera com: openssl rand -hex 32
API_KEY=

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=exodeploy
DB_PASSWORD=
DB_NAME=exodeploy
DB_SSLMODE=disable

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
