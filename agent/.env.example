# BastionDeploy Agent — configuration template
# Copie para .env e preencha os valores

# PostgreSQL (mesmas credenciais da API)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=exodeploy
DB_PASSWORD=
DB_NAME=exodeploy
DB_SSLMODE=disable

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# Discord (notificações de deploy — opcional)
DISCORD_WEBHOOK_URL=

# ─── Escolha UM dos modos abaixo ───

# Modo A: Cloudflare Tunnel (recomendado)
USE_TUNNEL_MODE=true
CLOUDFLARE_TUNNEL_TOKEN=

# Modo B: Nginx local com Let's Encrypt
# USE_TUNNEL_MODE=false
# CERTBOT_EMAIL=seu@email.com
